# Django
SECRET_KEY=django-insecure-docker-dev-change-in-production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
TEAMS_ENV_ID=local

# Database
DB_ENGINE=django.db.backends.postgresql
DB_NAME=mydb
DB_USER=postgres
DB_PASSWORD=secret
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/1

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7
